---
// src/pages/en/index.astro
// URL: /en/
// Английская главная. Стили - global.css через BaseLayout.

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects-en');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  lang="en"
  title="Dmitry Gladkih - C++ / Python developer"
  description="C++ / Python developer: engineering software, computer vision and measurement systems. Featured projects, stack and contacts."
>

  <!-- HERO BLOCK -->
  <section class="hero">
    <div class="container">
      <h1>Dmitry Gladkih</h1>
      <p class="hero-subtitle">
        <span class="accent">C++ / Python</span> developer ·
        <span class="accent">Computer Vision</span> ·
        <span class="accent">Backend</span> ·
        Measurement Systems
      </p>
      <p class="hero-description">
        I build engineering software that works with real hardware - computer vision algorithms,
        video processing from industrial cameras, measurement applications with GUI - and web
        backends: APIs, databases, deployment.
      </p>
      <p class="hero-description">
        C++ for high-performance computational libraries, Python for application systems and
        backend services with Django and FastAPI. I take my own projects all the way to
        production: PostgreSQL, Docker, nginx, self-hosted CI/CD.
      </p>
      <div class="hero-actions">  
        <a href="/en/projects/" class="btn btn-primary">Projects</a>
        <a href="https://github.com/MidnightFruit" class="btn btn-secondary" target="_blank" rel="noopener">GitHub ↗</a>
        <a href="/Dmitry_Gladkih_resume_EN.pdf" class="btn btn-secondary" target="_blank" rel="noopener">Resume PDF ↗</a>
      </div>
    </div>
  </section>

  <!-- FEATURED PROJECTS -->
  <section class="section">
    <div class="container">
      <h2>Featured projects</h2>
      <p class="section-lead">
        A few projects that show the full cycle - from task to result.
      </p>

      <div class="projects-grid">
        {featuredProjects.map(project => (
          <ProjectCard
            slug={project.id}
            title={project.data.title}
            description={project.data.description}
            stack={project.data.stack}
            status={project.data.status}
            github={project.data.github}
            live={project.data.live}
            lang="en"
          />
        ))}
      </div>

      <p class="section-more">
        <a href="/en/projects/">All projects →</a>
      </p>
    </div>
  </section>

  <!-- STACK -->
  <section class="section section-alt">
    <div class="container">
      <h2>Stack</h2>

      <div class="stack-grid">
        <div class="stack-group">
          <h3>Languages</h3>
          <p>Python · C++</p>
        </div>
        <div class="stack-group">
          <h3>Computer Vision</h3>
          <p>OpenCV · OpenCL · AruCo</p>
        </div>
        <div class="stack-group">
          <h3>Backend</h3>
          <p>Django · DRF · FastAPI · PostgreSQL · Redis · Celery</p>
        </div>
        <div class="stack-group">
          <h3>Desktop / GUI</h3>
          <p>PySide6 · multiprocessing</p>
        </div>
        <div class="stack-group">
          <h3>Infrastructure</h3>
          <p>Linux · Docker · nginx · GitLab CI/CD · Tailscale</p>
        </div>
        <div class="stack-group">
          <h3>Tooling</h3>
          <p>Git · pytest · Sphinx</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACTS -->
  <section class="section">
    <div class="container">
      <h2>Contact</h2>
      <p class="section-lead">
        Open to new projects in backend, computer vision, and engineering software.
      </p>
      <ul class="contacts-list">
        <li><a href="https://t.me/Midnight_Fruit" target="_blank" rel="noopener">Telegram: @Midnight_Fruit</a></li>
        <li><a href="mailto:dima.gladkikh.2016@mail.ru">Email: dima.gladkikh.2016@mail.ru</a></li>
        <li><a href="https://github.com/MidnightFruit" target="_blank" rel="noopener">GitHub: MidnightFruit</a></li>
      </ul>
    </div>
  </section>

</BaseLayout>
