---
// src/pages/en/projects/index.astro
// URL: /en/projects/

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import '../../../styles/projects-list.css';

const allProjects = await getCollection('projects-en');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const workProjects = sorted.filter(p => p.data.category === 'work');
const personalProjects = sorted.filter(p => p.data.category === 'personal');
---

<BaseLayout
  lang="en"
  title="Projects - Dmitry Gladkih"
  description="Projects by Dmitry Gladkih: work computer vision and measurement systems, personal pet projects and home infrastructure."
>
  <section class="page-section">
    <div class="container">
      <h1>Projects</h1>

      <h2 class="category-title">Work projects</h2>
      <p class="category-lead">
        What I do at Aviaspetstest - computer vision systems and measurement software.
      </p>
      <div class="projects-grid">
        {workProjects.map(p => (
          <ProjectCard
            slug={p.id}
            title={p.data.title}
            description={p.data.description}
            stack={p.data.stack}
            status={p.data.status}
            github={p.data.github}
            live={p.data.live}
            lang="en"
          />
        ))}
      </div>

      <h2 class="category-title">Personal projects &amp; infrastructure</h2>
      <p class="category-lead">
        What I build in my spare time - pet projects, home infrastructure, experiments.
      </p>
      <div class="projects-grid">
        {personalProjects.map(p => (
          <ProjectCard
            slug={p.id}
            title={p.data.title}
            description={p.data.description}
            stack={p.data.stack}
            status={p.data.status}
            github={p.data.github}
            live={p.data.live}
            lang="en"
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
