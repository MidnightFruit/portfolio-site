---
// src/pages/en/projects/[slug].astro
// URL: /en/projects/<slug>/

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import '../../../styles/project-detail.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects-en');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const statusLabels: Record<string, string> = {
  'active': 'Active',
  'completed': 'Completed',
  'in-progress': 'In progress',
};
const statusLabel = project.data.status ? statusLabels[project.data.status] : null;
---

<BaseLayout lang="en" title={`${project.data.title} - Dmitry Gladkikh`} description={project.data.description}>
  <article class="project-page">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/en/projects/">← All projects</a>
      </nav>

      <header class="project-header">
        <h1>{project.data.title}</h1>
        <div class="project-meta">
          {statusLabel && <span class={`status status-${project.data.status}`}>{statusLabel}</span>}
          {project.data.year && <span class="year">{project.data.year}</span>}
        </div>

        <div class="stack-list">
          {project.data.stack.map(tech => <span class="tech-tag">{tech}</span>)}
        </div>

        <div class="project-links">
          {project.data.github && (
            <a href={project.data.github} target="_blank" rel="noopener" class="link-external">
              GitHub ↗
            </a>
          )}
          {project.data.live && (
            <a href={project.data.live} target="_blank" rel="noopener" class="link-external">
              Live ↗
            </a>
          )}
        </div>
      </header>

      <div class="project-content">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
