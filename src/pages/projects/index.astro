---
// src/pages/projects/index.astro
//
// Страница со списком всех проектов.
// URL: /projects/
//
// Делим проекты по категориям: work / personal.

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import '../../styles/projects-list.css';

const allProjects = await getCollection('projects');

// Сортируем по order, потом разделяем на категории
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const workProjects = sorted.filter(p => p.data.category === 'work');
const personalProjects = sorted.filter(p => p.data.category === 'personal');
---

<BaseLayout
  title="Проекты — Дмитрий Гладких"
  description="Проекты Дмитрия Гладких: рабочие системы компьютерного зрения и измерений, личные pet-проекты и домашняя инфраструктура."
>
  <section class="page-section">
    <div class="container">
      <h1>Проекты</h1>

      <h2 class="category-title">Рабочие проекты</h2>
      <p class="category-lead">
        Что делаю в Авиаспецтесте — системы компьютерного зрения и измерительное ПО.
      </p>
      <div class="projects-grid">
        {workProjects.map(p => (
          <ProjectCard
            slug={p.id}
            title={p.data.title}
            description={p.data.description}
            stack={p.data.stack}
            status={p.data.status}
            github={p.data.github}
            live={p.data.live}
          />
        ))}
      </div>

      <h2 class="category-title">Личные проекты и инфраструктура</h2>
      <p class="category-lead">
        Что делаю в свободное время — pet-projects, домашняя инфраструктура, эксперименты.
      </p>
      <div class="projects-grid">
        {personalProjects.map(p => (
          <ProjectCard
            slug={p.id}
            title={p.data.title}
            description={p.data.description}
            stack={p.data.stack}
            status={p.data.status}
            github={p.data.github}
            live={p.data.live}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
