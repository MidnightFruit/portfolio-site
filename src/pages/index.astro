---
// src/pages/index.astro
//
// ГЛАВНАЯ СТРАНИЦА.
//
// В Astro файлы в src/pages/ автоматически становятся URL:
//   src/pages/index.astro       → /
//   src/pages/about.astro       → /about/
//   src/pages/projects/[slug].astro → /projects/что-то/  (динамические)
//
// Это файловый роутинг - не нужно настраивать urls.py как в Django.

import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
// Стили hero/btn/section/stack/contacts - в global.css (подключён через BaseLayout)

// Получаем все проекты из коллекции
const allProjects = await getCollection('projects');

// Фильтруем - только featured, сортируем по полю order
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="Дмитрий Гладких - C++ / Python разработчик"
  description="C++ / Python разработчик: инженерное ПО, системы компьютерного зрения и измерений. Избранные проекты, стек и контакты."
>

  <!-- HERO БЛОК -->
  <section class="hero">
    <div class="container">
      <h1>Дмитрий Гладких</h1>
      <p class="hero-subtitle">
        <span class="accent">C++ / Python</span> разработчик ·
        <span class="accent">Computer Vision</span> ·
        <span class="accent">Backend</span> ·
        Системы измерений
      </p>
      <p class="hero-description">
        Делаю инженерное ПО для работы с реальным оборудованием - алгоритмы компьютерного
        зрения, обработку видеопотока с промышленных камер, измерительные приложения с GUI -
        и веб-backend: API, базы данных, развёртывание.
      </p>
      <p class="hero-description">
        C++ - для производительных вычислительных библиотек, Python - для прикладных систем
        и backend-сервисов на Django и FastAPI. Свои проекты довожу до прода сам:
        PostgreSQL, Docker, nginx, собственный CI/CD.
      </p>
      <div class="hero-actions">
        <a href="/projects/" class="btn btn-primary">Проекты</a>
        <a href="https://github.com/MidnightFruit" class="btn btn-secondary" target="_blank" rel="noopener">GitHub ↗</a>
        <a href="/Дмитрий_Гладких_резюме_RU.pdf" class="btn btn-secondary" target="_blank" rel="noopener">Резюме PDF ↗</a>
      </div>
    </div>
  </section>

  <!-- ИЗБРАННЫЕ ПРОЕКТЫ -->
  <section class="section">
    <div class="container">
      <h2>Избранные проекты</h2>
      <p class="section-lead">
        Несколько проектов, которые показывают полный цикл - от задачи до результата.
      </p>

      <div class="projects-grid">
        {featuredProjects.map(project => (
          <ProjectCard
            slug={project.id}
            title={project.data.title}
            description={project.data.description}
            stack={project.data.stack}
            status={project.data.status}
            github={project.data.github}
            live={project.data.live}
          />
        ))}
      </div>

      <p class="section-more">
        <a href="/projects/">Все проекты →</a>
      </p>
    </div>
  </section>

  <!-- СТЕК -->
  <section class="section section-alt">
    <div class="container">
      <h2>Стек</h2>

      <div class="stack-grid">
        <div class="stack-group">
          <h3>Languages</h3>
          <p>Python · C++</p>
        </div>
        <div class="stack-group">
          <h3>Computer Vision</h3>
          <p>OpenCV · OpenCL · AruCo</p>
        </div>
        <div class="stack-group">
          <h3>Backend</h3>
          <p>Django · DRF · FastAPI · PostgreSQL · Redis · Celery</p>
        </div>
        <div class="stack-group">
          <h3>Desktop / GUI</h3>
          <p>PySide6 · multiprocessing</p>
        </div>
        <div class="stack-group">
          <h3>Infrastructure</h3>
          <p>Linux · Docker · nginx · GitLab CI/CD · Tailscale</p>
        </div>
        <div class="stack-group">
          <h3>Tooling</h3>
          <p>Git · pytest · Sphinx</p>
        </div>
      </div>
    </div>
  </section>

  <!-- КОНТАКТЫ -->
  <section class="section">
    <div class="container">
      <h2>Контакты</h2>
      <p class="section-lead">
        Открыт к новым задачам в backend, computer vision и инженерной разработке.
      </p>
      <ul class="contacts-list">
        <li><a href="https://t.me/Midnight_Fruit" target="_blank" rel="noopener">Telegram: @Midnight_Fruit</a></li>
        <li><a href="mailto:dima.gladkikh.2016@mail.ru">Email: dima.gladkikh.2016@mail.ru</a></li>
        <li><a href="https://github.com/MidnightFruit" target="_blank" rel="noopener">GitHub: MidnightFruit</a></li>
      </ul>
    </div>
  </section>

</BaseLayout>
