---
// src/layouts/BaseLayout.astro
//
// ЧТО ЭТО ЗА ФАЙЛ:
// Layout (раскладка) — это общий каркас, в который оборачиваются страницы.
// Здесь живут: <html>, <head>, <header>, <footer> — всё, что повторяется.
// Сама страница вставляется через <slot />.
//
// Аналог в Django: base.html, который extends другие шаблоны.
//
// СИНТАКСИС ASTRO:
// Файл делится на 2 части разделителем ---
// Сверху (между ---) — JavaScript/TypeScript: импорты, переменные, логика.
// Снизу — HTML, в который можно вставлять {переменные} в фигурных скобках.

import '../styles/global.css';

// Принимаем title как props (передаётся со страницы при использовании layout)
interface Props {
  title: string;
  description?: string;
  lang?: "ru" | "en";
}

const { title, description, lang } = Astro.props;

// Определяем язык страницы по её пути: всё под /en/ — английская версия.
// Можно переопределить явным props lang.
const pathname = Astro.url.pathname;
const isEn = lang ? lang === "en" : (pathname === "/en" || pathname.startsWith("/en/"));
const currentLang = isEn ? "en" : "ru";

// Дефолтный description зависит от языка — иначе на английских страницах,
// которые не передали свой description, в <head> попадал бы русский текст.
const metaDescription = description ?? (isEn
  ? "Dmitry Gladkih — C++ / Python developer. Computer Vision and measurement systems."
  : "Дмитрий Гладких — C++ / Python разработчик. Computer Vision и системы измерений.");

// Open Graph / Twitter Card. Абсолютный URL строим из Astro.site (домен из
// astro.config.mjs) и текущего пути. og:image своя для каждого языка.
const ogUrl = new URL(pathname, Astro.site).href;

// hreflang: связываем языковые версии одной страницы. Пути зеркальны
// (/projects/x/ ↔ /en/projects/x/), поэтому пару можно вычислить из pathname.
// Без этих ссылок поисковик видит RU- и EN-страницы как независимые документы
// с похожей структурой и сам решает, какую показывать — часто не ту.
// x-default указывает на EN: авторедирект уводит все не-русские браузеры на /en/.
const rootPath = isEn
  ? (pathname === "/en" || pathname === "/en/" ? "/" : pathname.slice(3))
  : pathname;
const ruUrl = new URL(rootPath, Astro.site).href;
const enUrl = new URL(rootPath === "/" ? "/en/" : `/en${rootPath}`, Astro.site).href;
const ogImage = isEn
  ? "https://gladkih.xyz/og-image-en.png"
  : "https://gladkih.xyz/og-image.png";

// Префикс для внутренних ссылок: на английской версии все ссылки в хедере
// должны вести на /en/..., иначе клик по логотипу/меню уводит на русскую
// версию (а после осознанного выбора языка редирект уже не вернёт обратно).
const base = isEn ? "/en" : "";

// Подписи навигации — на текущем языке.
const nav = isEn
  ? { home: "Home", projects: "Projects", about: "About" }
  : { home: "Главная", projects: "Проекты", about: "Обо мне" };

// Имя в логотипе — на текущем языке (на английской версии транслитерация).
const siteName = isEn ? "Dmitry Gladkih" : "Дмитрий Гладких";
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <!--
      Автоопределение языка браузера (сайт статический, без SSR).
      Скрипт стоит первым в <head> и блокирующий — выполняется до отрисовки,
      чтобы не было мигания русской версии перед редиректом.
      Логика: если пользователь ещё НЕ делал осознанный выбор языка
      (нет ключа lang-preference в localStorage), мы на русской версии,
      а язык браузера не русский — уводим на /en/ текущей страницы.
    -->
    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem("lang-preference");
          if (pref) return; // осознанный выбор уже сделан — не вмешиваемся
          var path = location.pathname;
          var isEn = path === "/en" || path.indexOf("/en/") === 0;
          if (isEn) return; // уже на английской версии
          var lang = (navigator.language || "").toLowerCase();
          if (lang && lang.indexOf("ru") !== 0) {
            location.replace("/en" + (path === "/" ? "/" : path));
          }
        } catch (e) {
          /* localStorage может быть недоступен — тихо игнорируем */
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Канонический адрес и связь языковых версий (см. комментарий выше) -->
    <link rel="canonical" href={ogUrl} />
    <link rel="alternate" hreflang="ru" href={ruUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={isEn ? "en_US" : "ru_RU"} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href={`${base}/`} class="logo">{siteName}</a>
        <nav class="site-nav">
          <a href={`${base}/`}>{nav.home}</a>
          <a href={`${base}/projects/`}>{nav.projects}</a>
          <a href={`${base}/about/`}>{nav.about}</a>
          <div class="lang-switcher">
            <button type="button" data-lang="ru" class:list={["lang-btn", { active: currentLang === "ru" }]}>RU</button>
            <button type="button" data-lang="en" class:list={["lang-btn", { active: currentLang === "en" }]}>EN</button>
          </div>
        </nav>
      </div>
    </header>

    <!--
      Переключатель языка. Записывает осознанный выбор в тот же ключ
      lang-preference, поэтому авторедирект по navigator.language больше
      не сработает, и переводит на соответствующую версию текущей страницы.
    -->
    <script is:inline>
      (function () {
        // Приводим путь к русскому (базовому) виду: убираем префикс /en.
        function toBasePath(path) {
          if (path === "/en" || path === "/en/") return "/";
          if (path.indexOf("/en/") === 0) return path.slice(3);
          return path;
        }
        var buttons = document.querySelectorAll(".lang-btn");
        for (var i = 0; i < buttons.length; i++) {
          buttons[i].addEventListener("click", function () {
            var lang = this.getAttribute("data-lang");
            try {
              localStorage.setItem("lang-preference", lang);
            } catch (e) {}
            var base = toBasePath(location.pathname);
            var target = lang === "en" ? "/en" + (base === "/" ? "/" : base) : base;
            if (target !== location.pathname) {
              location.href = target;
            }
          });
        }
      })();
    </script>

    <main>
      <!-- Сюда вставится содержимое конкретной страницы -->
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          Built with <a href="https://astro.build">Astro</a> ·
          Deployed via self-hosted GitLab CI/CD ·
          <a href="https://github.com/MidnightFruit" target="_blank" rel="noopener">View source</a>
        </p>
      </div>
    </footer>

    <style is:global>
      /* Глобальные стили — применяются ко всему сайту.
         is:global нужен потому что Astro по умолчанию изолирует стили в компонентах. */

      :root {
        /* CSS-переменные — удобно для централизованной смены цветов */
        --color-bg: #0d1117;
        --color-surface: #161b22;
        --color-border: #30363d;
        --color-text: #c9d1d9;
        --color-text-dim: #8b949e;
        --color-accent: #58a6ff;
        --color-accent-hover: #79b8ff;
        --font-mono: ui-monospace, 'SF Mono', 'Cascadia Mono', 'Roboto Mono', Consolas, monospace;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: color 0.15s;
      }

      a:hover {
        color: var(--color-accent-hover);
      }

      h1, h2, h3, h4 {
        color: #f0f6fc;
        line-height: 1.2;
      }

      code {
        font-family: var(--font-mono);
        font-size: 0.9em;
        background: var(--color-surface);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        border: 1px solid var(--color-border);
      }

      pre {
        font-family: var(--font-mono);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 1rem;
        overflow-x: auto;
        margin: 1rem 0;
        line-height: 1.5;
      }

      pre code {
        background: none;
        border: none;
        padding: 0;
      }

      /* === HEADER === */
      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 0;
        background: var(--color-bg);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .site-header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-weight: 600;
        color: #f0f6fc;
        font-size: 1.05rem;
      }

      .site-nav {
        display: flex;
        gap: 1.5rem;
      }

      .site-nav a {
        color: var(--color-text-dim);
        font-size: 0.95rem;
      }

      .site-nav a:hover {
        color: var(--color-text);
      }

      /* === ПЕРЕКЛЮЧАТЕЛЬ ЯЗЫКА === */
      .lang-switcher {
        display: flex;
        gap: 0.25rem;
        align-items: center;
      }

      .lang-btn {
        font-family: var(--font-sans);
        font-size: 0.85rem;
        color: var(--color-text-dim);
        background: none;
        border: 1px solid transparent;
        border-radius: 4px;
        padding: 0.15rem 0.4rem;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s;
      }

      .lang-btn:hover {
        color: var(--color-text);
      }

      .lang-btn.active {
        color: var(--color-accent);
        border-color: var(--color-border);
      }

      /* === FOOTER === */
      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 2rem 0;
        margin-top: 4rem;
        color: var(--color-text-dim);
        font-size: 0.9rem;
      }

      .site-footer a {
        color: var(--color-text-dim);
        border-bottom: 1px dotted var(--color-text-dim);
      }

      .site-footer a:hover {
        color: var(--color-accent);
        border-bottom-color: var(--color-accent);
      }
    </style>
  </body>
</html>
