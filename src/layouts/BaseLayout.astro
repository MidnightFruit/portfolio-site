---
// src/layouts/BaseLayout.astro
//
// ЧТО ЭТО ЗА ФАЙЛ:
// Layout (раскладка) — это общий каркас, в который оборачиваются страницы.
// Здесь живут: <html>, <head>, <header>, <footer> — всё, что повторяется.
// Сама страница вставляется через <slot />.
//
// Аналог в Django: base.html, который extends другие шаблоны.
//
// СИНТАКСИС ASTRO:
// Файл делится на 2 части разделителем ---
// Сверху (между ---) — JavaScript/TypeScript: импорты, переменные, логика.
// Снизу — HTML, в который можно вставлять {переменные} в фигурных скобках.

// Принимаем title как props (передаётся со страницы при использовании layout)
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Дмитрий Гладких — C++ / Python разработчик. Computer Vision и системы измерений." } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">Дмитрий Гладких</a>
        <nav class="site-nav">
          <a href="/">Главная</a>
          <a href="/projects/">Проекты</a>
          <a href="/about/">Обо мне</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- Сюда вставится содержимое конкретной страницы -->
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          Built with <a href="https://astro.build">Astro</a> ·
          Deployed via self-hosted GitLab CI/CD ·
          <a href="https://github.com/MidnightFruit" target="_blank" rel="noopener">View source</a>
        </p>
      </div>
    </footer>

    <style is:global>
      /* Глобальные стили — применяются ко всему сайту.
         is:global нужен потому что Astro по умолчанию изолирует стили в компонентах. */

      :root {
        /* CSS-переменные — удобно для централизованной смены цветов */
        --color-bg: #0d1117;
        --color-surface: #161b22;
        --color-border: #30363d;
        --color-text: #c9d1d9;
        --color-text-dim: #8b949e;
        --color-accent: #58a6ff;
        --color-accent-hover: #79b8ff;
        --font-mono: ui-monospace, 'SF Mono', 'Cascadia Mono', 'Roboto Mono', Consolas, monospace;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: color 0.15s;
      }

      a:hover {
        color: var(--color-accent-hover);
      }

      h1, h2, h3, h4 {
        color: #f0f6fc;
        line-height: 1.2;
      }

      code {
        font-family: var(--font-mono);
        font-size: 0.9em;
        background: var(--color-surface);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        border: 1px solid var(--color-border);
      }

      pre {
        font-family: var(--font-mono);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 1rem;
        overflow-x: auto;
        margin: 1rem 0;
        line-height: 1.5;
      }

      pre code {
        background: none;
        border: none;
        padding: 0;
      }

      /* === HEADER === */
      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 0;
        background: var(--color-bg);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .site-header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-weight: 600;
        color: #f0f6fc;
        font-size: 1.05rem;
      }

      .site-nav {
        display: flex;
        gap: 1.5rem;
      }

      .site-nav a {
        color: var(--color-text-dim);
        font-size: 0.95rem;
      }

      .site-nav a:hover {
        color: var(--color-text);
      }

      /* === FOOTER === */
      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 2rem 0;
        margin-top: 4rem;
        color: var(--color-text-dim);
        font-size: 0.9rem;
      }

      .site-footer a {
        color: var(--color-text-dim);
        border-bottom: 1px dotted var(--color-text-dim);
      }

      .site-footer a:hover {
        color: var(--color-accent);
        border-bottom-color: var(--color-accent);
      }
    </style>
  </body>
</html>
